class Solution:
    def maxArea(self, height: List[int]) -> int:
        l = 0
        r = len(height) - 1
        max_area = 0

        while l < r:
            if height[l]  < height[r]:
                current_area = height[l] * (r - l)
                l += 1
                if current_area > max_area:
                    max_area = current_area
            else:
                current_area = height[r] * (r - l)
                r -= 1
                if current_area > max_area:
                    max_area = current_area

        return max_area
