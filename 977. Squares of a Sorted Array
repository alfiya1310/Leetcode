class Solution:
    def sortedSquares(self, nums: List[int]) -> List[int]:
        left = 0
        right = len(nums) - 1

        result = [0] * len(nums)
        rp = len(result) - 1

        while (left <= right):
            if abs(nums[left]) < abs(nums[right]):
                result[rp] = nums[right] * nums[right]
                right -= 1
                rp -= 1
            else:
                result[rp] = nums[left] * nums[left]
                left += 1
                rp -= 1

        return result
