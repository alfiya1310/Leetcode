class Solution:
    def isSubsequence(self, s: str, t: str) -> bool:
        first = 0 #s
        second = 0 #t

        while first < len(s) and second < len(t):
            if s[first] == t[second]:
                first += 1
                second += 1
            else:
                second += 1

        return first == len(s)
