class Solution:
    def canConstruct(self, ransomNote: str, magazine: str) -> bool:
        
        r = {}
        m = {}
        
        for ch in magazine:
            m[ch] = m.get(ch, 0) + 1
            
        for ch in ransomNote:
            r[ch] = r.get(ch, 0) + 1
            
        for key, value in r.items():
            if key not in m or m[key] < value:
                return False
                
        return True

