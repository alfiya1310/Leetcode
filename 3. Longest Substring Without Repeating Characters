class Solution:
    def lengthOfLongestSubstring(self, s: str) -> int:
        
        maxx = 0
        left = 0
        seen = set()

        for right in range(len(s)):
            while s[right] in seen:
                seen.discard(s[left])
                left += 1

            seen.add(s[right])

            maxx = max(maxx, right - left + 1)

        return maxx
