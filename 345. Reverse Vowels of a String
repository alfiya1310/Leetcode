class Solution:
    def reverseVowels(self, s: str) -> str:
        vowels = {'a', 'e', 'i', 'o', 'u', 'A', 'E', 'I', 'O', 'U'}
        reversedS = list(s)
        l = 0
        r = len(reversedS) - 1

        while (l < r):
            if reversedS[l] not in vowels:
                l += 1
            elif reversedS[r] not in vowels:
                r -= 1
            elif reversedS[l] in vowels and reversedS[r] in vowels:
                reversedS[l], reversedS[r] = reversedS[r], reversedS[l]
                l += 1
                r -= 1

        return ''.join(reversedS)
